---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About · kivozo.com" ogSlug="about">
  <h1>About</h1>
  <p>
    <strong>kivozo.com</strong> is a personal sandbox for small, fun, and useful things —
    games, tools, dictionaries, utilities, experiments, and random projects.
  </p>
  <p>
    The site is a static <a href="https://astro.build">Astro</a> build deployed on
    <a href="https://pages.cloudflare.com">Cloudflare Pages</a>. Each project lives
    in its own folder under <code>src/content/projects/&lt;category&gt;/&lt;slug&gt;/</code>
    and is auto-indexed on the homepage.
  </p>
  <p>
    See <a href="/projects">all projects</a> or browse by category from the homepage.
  </p>
</BaseLayout>
